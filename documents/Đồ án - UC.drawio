        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam defaultFontName \&quot;Arial\&quot;\nskinparam shadowing false\nskinparam ParticipantPadding 20\n\nactor \&quot;Khách hàng\&quot; as KH\nboundary \&quot;Giao diện\&quot; as GD\ncontrol \&quot;Hệ thống\&quot; as HT\nentity \&quot;Cơ sở dữ liệu\&quot; as CSDL\n\n== Tìm kiếm sản phẩm ==\nKH -&gt; GD : Nhập từ khóa tìm kiếm\nactivate GD\nGD -&gt; HT : Gửi yêu cầu tìm kiếm\ndeactivate GD\nactivate HT\nHT -&gt; CSDL : Truy vấn sản phẩm theo từ khóa\nactivate CSDL\nCSDL --&gt; HT : Danh sách sản phẩm\ndeactivate CSDL\nHT --&gt; GD : Gửi kết quả tìm kiếm\nactivate GD\nGD --&gt; KH : Hiển thị kết quả\ndeactivate GD\ndeactivate HT\n\n== Lọc theo danh mục ==\nKH -&gt; GD : Chọn danh mục\nactivate GD\nGD -&gt; HT : Gửi yêu cầu lọc danh mục\ndeactivate GD\nactivate HT\nHT -&gt; CSDL : Truy vấn theo danh mục\nactivate CSDL\nCSDL --&gt; HT : Danh sách sản phẩm đã lọc\ndeactivate CSDL\nHT --&gt; GD : Gửi kết quả lọc\nactivate GD\nGD --&gt; KH : Hiển thị kết quả lọc\ndeactivate GD\ndeactivate HT\n\n== Lọc theo giá ==\nKH -&gt; GD : Chọn mức giá\nactivate GD\nGD -&gt; HT : Gửi yêu cầu lọc giá\ndeactivate GD\nactivate HT\nHT -&gt; CSDL : Truy vấn theo mức giá\nactivate CSDL\nCSDL --&gt; HT : Danh sách sản phẩm đã lọc\ndeactivate CSDL\nHT --&gt; GD : Gửi kết quả lọc\nactivate GD\nGD --&gt; KH : Hiển thị kết quả lọc\ndeactivate GD\ndeactivate HT\n\n== Sắp xếp kết quả ==\nKH -&gt; GD : Chọn tiêu chí sắp xếp (giá, tên,...)\nactivate GD\nGD -&gt; HT : Gửi yêu cầu sắp xếp\ndeactivate GD\nactivate HT\nHT -&gt; CSDL : Truy vấn và sắp xếp kết quả\nactivate CSDL\nCSDL --&gt; HT : Danh sách sản phẩm đã sắp xếp\ndeactivate CSDL\nHT --&gt; GD : Gửi danh sách đã sắp xếp\nactivate GD\nGD --&gt; KH : Hiển thị kết quả đã sắp xếp\ndeactivate GD\ndeactivate HT\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="yXYcxn9zfyFDSBF0G3_M-44">
