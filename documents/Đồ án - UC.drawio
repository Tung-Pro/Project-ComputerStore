        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam defaultFontName \&quot;Arial\&quot;\nskinparam shadowing false\nskinparam ParticipantPadding 20\n\nactor \&quot;Admin\&quot; as AD\nboundary \&quot;Giao diện\&quot; as GD\ncontrol \&quot;Hệ thống\&quot; as HT\nentity \&quot;Cơ sở dữ liệu\&quot; as CSDL\n\n== Xem danh sách sản phẩm ==\nAD -&gt; GD : Chọn mục \&quot;Quản lý sản phẩm\&quot;\nactivate GD\nGD -&gt; HT : Yêu cầu danh sách sản phẩm\ndeactivate GD\nactivate HT\nHT -&gt; CSDL : Truy vấn danh sách sản phẩm\nactivate CSDL\nCSDL --&gt; HT : Trả về danh sách\ndeactivate CSDL\nHT --&gt; GD : Gửi dữ liệu\ndeactivate HT\nactivate GD\nGD --&gt; AD : Hiển thị danh sách sản phẩm\ndeactivate GD\n\n== Thêm sản phẩm mới ==\nAD -&gt; GD : Chọn \&quot;Thêm sản phẩm mới\&quot;\nactivate GD\nGD --&gt; AD : Hiển thị form thêm sản phẩm\nAD -&gt; GD : Nhập thông tin sản phẩm\nAD -&gt; GD : Nhấn nút \&quot;Lưu\&quot;\nGD -&gt; HT : Gửi thông tin sản phẩm mới\ndeactivate GD\nactivate HT\nHT -&gt; HT : Kiểm tra tính hợp lệ\n\nalt Dữ liệu hợp lệ\n    HT -&gt; CSDL : Lưu thông tin sản phẩm mới\n    activate CSDL\n    CSDL --&gt; HT : Xác nhận đã lưu\n    deactivate CSDL\n    HT --&gt; GD : Thông báo thành công\n    activate GD\n    GD --&gt; AD : Hiển thị thông báo thêm thành công\n    deactivate GD\nelse Dữ liệu không hợp lệ\n    HT --&gt; GD : Báo lỗi\n    activate GD\n    GD --&gt; AD : Hiển thị thông báo lỗi\n    deactivate GD\nend\ndeactivate HT\n\n== Chỉnh sửa sản phẩm ==\nAD -&gt; GD : Chọn sản phẩm cần sửa\nactivate GD\nGD -&gt; HT : Yêu cầu thông tin sản phẩm\ndeactivate GD\nactivate HT\nHT -&gt; CSDL : Truy vấn thông tin sản phẩm\nactivate CSDL\nCSDL --&gt; HT : Trả về thông tin\ndeactivate CSDL\nHT --&gt; GD : Gửi dữ liệu\ndeactivate HT\nactivate GD\nGD --&gt; AD : Hiển thị form chỉnh sửa\n\nAD -&gt; GD : Cập nhật thông tin và gửi\nGD -&gt; HT : Gửi dữ liệu cập nhật\ndeactivate GD\nactivate HT\nHT -&gt; HT : Kiểm tra tính hợp lệ\n\nalt Dữ liệu hợp lệ\n    HT -&gt; CSDL : Cập nhật thông tin sản phẩm\n    activate CSDL\n    CSDL --&gt; HT : Xác nhận cập nhật\n    deactivate CSDL\n    HT --&gt; GD : Thông báo thành công\n    activate GD\n    GD --&gt; AD : Hiển thị thông báo cập nhật thành công\n    deactivate GD\nelse Dữ liệu không hợp lệ\n    HT --&gt; GD : Báo lỗi\n    activate GD\n    GD --&gt; AD : Hiển thị thông báo lỗi\n    deactivate GD\nend\ndeactivate HT\n\n== Xóa sản phẩm ==\nAD -&gt; GD : Chọn sản phẩm cần xóa\nactivate GD\nGD --&gt; AD : Hiển thị hộp thoại xác nhận\nAD -&gt; GD : Xác nhận xóa\nGD -&gt; HT : Gửi yêu cầu xóa\ndeactivate GD\nactivate HT\nHT -&gt; CSDL : Xóa sản phẩm\nactivate CSDL\nCSDL --&gt; HT : Xác nhận đã xóa\ndeactivate CSDL\nHT --&gt; GD : Thông báo kết quả\ndeactivate HT\nactivate GD\nGD --&gt; AD : Hiển thị thông báo xóa thành công\ndeactivate GD\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="HZAlYfvnskxPnPfZF7u4-1">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" parent="1" vertex="1">
            <mxGeometry x="1579" y="1176" width="794" height="1604" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
