        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam defaultFontName \&quot;Arial\&quot;\nskinparam shadowing false\nskinparam ParticipantPadding 20\n\nactor \&quot;Admin\&quot; as AD\nboundary \&quot;Giao diện\&quot; as GD\ncontrol \&quot;Hệ thống\&quot; as HT\nentity \&quot;Cơ sở dữ liệu\&quot; as CSDL\n\n== Xem danh sách danh mục ==\nAD -&gt; GD : Chọn mục \&quot;Quản lý danh mục\&quot;\nactivate GD\nGD -&gt; HT : Yêu cầu danh sách danh mục\ndeactivate GD\nactivate HT\nHT -&gt; CSDL : Truy vấn danh sách danh mục\nactivate CSDL\nCSDL --&gt; HT : Trả về danh sách\ndeactivate CSDL\nHT --&gt; GD : Gửi dữ liệu\ndeactivate HT\nactivate GD\nGD --&gt; AD : Hiển thị danh sách danh mục\ndeactivate GD\n\n== Thêm danh mục mới ==\nAD -&gt; GD : Chọn \&quot;Thêm danh mục mới\&quot;\nactivate GD\nGD --&gt; AD : Hiển thị form thêm danh mục\nAD -&gt; GD : Nhập tên, mô tả, danh mục cha (nếu có)\nGD -&gt; HT : Gửi thông tin danh mục mới\ndeactivate GD\nactivate HT\nHT -&gt; HT : Kiểm tra tính hợp lệ\n\nalt Dữ liệu hợp lệ\n    HT -&gt; CSDL : Lưu thông tin danh mục mới\n    activate CSDL\n    CSDL --&gt; HT : Xác nhận đã lưu\n    deactivate CSDL\n    HT --&gt; GD : Thông báo thành công\n    activate GD\n    GD --&gt; AD : Hiển thị thông báo thêm thành công\n    deactivate GD\nelse Dữ liệu không hợp lệ\n    HT --&gt; GD : Báo lỗi\n    activate GD\n    GD --&gt; AD : Hiển thị thông báo lỗi\n    deactivate GD\nend\ndeactivate HT\n\n== Chỉnh sửa danh mục ==\nAD -&gt; GD : Chọn danh mục cần sửa\nactivate GD\nGD -&gt; HT : Yêu cầu thông tin danh mục\ndeactivate GD\nactivate HT\nHT -&gt; CSDL : Truy vấn thông tin danh mục\nactivate CSDL\nCSDL --&gt; HT : Trả về thông tin\ndeactivate CSDL\nHT --&gt; GD : Gửi dữ liệu\ndeactivate HT\nactivate GD\nGD --&gt; AD : Hiển thị form chỉnh sửa\n\nAD -&gt; GD : Cập nhật thông tin và gửi\nGD -&gt; HT : Gửi dữ liệu cập nhật\ndeactivate GD\nactivate HT\nHT -&gt; HT : Kiểm tra tính hợp lệ\n\nalt Dữ liệu hợp lệ\n    HT -&gt; CSDL : Cập nhật thông tin danh mục\n    activate CSDL\n    CSDL --&gt; HT : Xác nhận cập nhật\n    deactivate CSDL\n    HT --&gt; GD : Thông báo thành công\n    activate GD\n    GD --&gt; AD : Hiển thị thông báo cập nhật thành công\n    deactivate GD\nelse Dữ liệu không hợp lệ\n    HT --&gt; GD : Báo lỗi\n    activate GD\n    GD --&gt; AD : Hiển thị thông báo lỗi\n    deactivate GD\nend\ndeactivate HT\n\n== Xóa danh mục ==\nAD -&gt; GD : Chọn danh mục cần xóa\nactivate GD\nGD -&gt; HT : Kiểm tra danh mục có sản phẩm không\ndeactivate GD\nactivate HT\nHT -&gt; CSDL : Truy vấn số lượng sản phẩm trong danh mục\nactivate CSDL\nCSDL --&gt; HT : Trả về số lượng\ndeactivate CSDL\n\nalt Danh mục có chứa sản phẩm\n    HT --&gt; GD : Thông báo không thể xóa\n    activate GD\n    GD --&gt; AD : Hiển thị thông báo không thể xóa\n    deactivate GD\nelse Danh mục không chứa sản phẩm\n    HT --&gt; GD : Yêu cầu xác nhận\n    deactivate HT\n    activate GD\n    GD --&gt; AD : Hiển thị hộp thoại xác nhận\n    AD -&gt; GD : Xác nhận xóa\n    GD -&gt; HT : Gửi yêu cầu xóa\n    deactivate GD\n    activate HT\n    HT -&gt; CSDL : Xóa danh mục\n    activate CSDL\n    CSDL --&gt; HT : Xác nhận đã xóa\n    deactivate CSDL\n    HT --&gt; GD : Thông báo kết quả\n    deactivate HT\n    activate GD\n    GD --&gt; AD : Hiển thị thông báo xóa thành công\n    deactivate GD\nend\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="IfIFRjEEC732i3V0cQIc-1">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" parent="1" vertex="1">
            <mxGeometry x="1598" y="1204" width="944" height="1788" as="geometry" />
          </mxCell>
